// A simple octahedron made of 8 triangles.
function makeOctahedronModel({ scale = 1 }) {
    const s = scale;
    const vertices = [
        { x: 0,  y:  s, z: 0 },  // 0 top
        { x:  s, y:  0, z: 0 },  // 1 +X
        { x:  0, y:  0, z:  s }, // 2 +Z
        { x: -s, y:  0, z: 0 },  // 3 -X
        { x:  0, y:  0, z: -s }, // 4 -Z
        { x:  0, y: -s, z: 0 },  // 5 bottom
    ];
    const polys = [
        // top cap (winding to face outward)
        { vIndexes: [0, 1, 2] },
        { vIndexes: [0, 2, 3] },
        { vIndexes: [0, 3, 4] },
        { vIndexes: [0, 4, 1] },
        // bottom cap
        { vIndexes: [5, 2, 1] },
        { vIndexes: [5, 3, 2] },
        { vIndexes: [5, 4, 3] },
        { vIndexes: [5, 1, 4] },
    ];
    return { vertices, polys };
}

// Factory to choose target model based on selector above
function makeTargetModel() {
    switch (TARGET_MODEL_TYPE) {
        case 'cube':
            return makeCubeModel({ scale: targetRadius });
        case 'octa':
            return makeOctahedronModel({ scale: targetRadius });
        case 'cube-recursive':
        default:
            return optimizeModel(makeRecursiveCubeModel({
                recursionLevel: 1,
                splitFn: mengerSpongeSplit,
                scale: targetRadius
            }));
    }
}

